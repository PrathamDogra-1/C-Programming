#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n,count=0;
    scanf("%d\n",&n);
    int list[n+1];
    int visited[n+1];
    for(int i=0;i<n;i++){
        scanf("%d",&list[i]);
        visited[i]=0;
    }
    for(int b=0;b<n;b++){
        if(visited[b]==1){
            continue;
        }int found=0;
        for(int i=b+1;i<n;i++){
           if(list[i]==list[b]){
            visited[i]=1;
            found=1;
           }
    }
    if(found==1){
        count++;
    }
}   if(count!=0){
    printf("%d",count);}
    else{
        printf("0");
    }   

    return 0;
}
