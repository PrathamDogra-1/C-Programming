#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int main(){
    int row,coll;
    scanf("%d %d",&row,&coll);
    int matrix[row][coll];
    for(int i=0;i<row;i++){
        for(int j=0;j<coll;j++){
        scanf("%d",&matrix[i][j]);
        }
    }
    for(int a=0;a<row;a++){
        for(int b=0;b<coll;b++){
            printf("%d ",matrix[a][b]);
        }
        printf("\n");
    }
    return 0;
}
