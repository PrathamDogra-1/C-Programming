#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d",&n);
    int list[n];
    for(int i=0;i<n;i++){
        scanf("%d",&list[i]);
    }
    for(int a=0;a<n;a++){
        for(int b=a+1;b<n;b++){
            if(list[a]==list[b]){
                
            for(int i=b;i<n-1;i++){
                list[i]=list[i+1];
            }
            n--;
            b--;
        }
    }}
    if(n!=0){
    for(int i=0;i<n;i++){
        printf("%d ",list[i]);
    }}
    else{
        printf("No elements left");
    }
    return 0;
}
