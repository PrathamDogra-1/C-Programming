#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int main() {
    int r, c;
    scanf("%d %d", &r, &c);
    int A[r][c], B[r][c], diff[r][c];
    for (int i = 0; i < r; i++){
        for (int j = 0; j < c; j++){
            scanf("%d", &A[i][j]);
        }
    }
    for (int i = 0; i < r; i++){
        for (int j = 0; j < c; j++){
            scanf("%d", &B[i][j]);
        }
    }
    for (int i = 0; i < r; i++){
        for (int j = 0; j < c; j++){
            diff[i][j] = A[i][j] - B[i][j];
        }
    }    
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++){
            printf("%d ", diff[i][j]);
    }
        printf("\n");
    }
    return 0;
}
