#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int main(){
    int row,coll,sum1=0,sum2=0;
    scanf("%d %d",&row,&coll);
    int matrix[row][coll];
    for(int i=0;i<row;i++){
        for(int j=0;j<coll;j++){
        scanf("%d",&matrix[i][j]);
        }
    }
    for(int a=0;a<row;a++){
        for(int b=0;b<coll;b++){
            sum1+=matrix[a][b];
            
        }
        printf("%d\n",sum1);
        sum1=0;
}   
    for(int a=0;a<coll;a++){
        for(int b=0;b<row;b++){
            sum2+=matrix[b][a];
            
        }
        printf("%d\n",sum2);
        sum2=0;
}
    
    return 0;
}
